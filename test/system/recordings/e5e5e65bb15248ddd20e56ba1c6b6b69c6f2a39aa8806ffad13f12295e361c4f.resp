data: {"candidates": [{"content": {"role": "model","parts": [{"text": ".  This scattered blue light is what we see when we look at the sky.  Violet light is actually scattered even more than blue, but our eyes are more sensitive to blue, and the sun emits slightly less violet light.\n"}]},"finishReason": "STOP"}],"usageMetadata": {"promptTokenCount": 17,"candidatesTokenCount": 144,"totalTokenCount": 161,"trafficType": "ON_DEMAND","promptTokensDetails": [{"modality": "TEXT","tokenCount": 17}],"candidatesTokensDetails": [{"modality": "TEXT","tokenCount": 144}]},"modelVersion": "gemini-1.5-flash-002","createTime": "2025-05-09T22:52:50.766843Z","responseId": "QoceaPvmLuWcmecPwqig4Ag"}

