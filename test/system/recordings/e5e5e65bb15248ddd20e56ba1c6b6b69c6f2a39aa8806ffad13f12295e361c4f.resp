data: {"candidates": [{"content": {"role": "model","parts": [{"text": "\n\nThe sky is blue because of a phenomenon called Rayleigh scattering.  Sunlight is"}]}}],"usageMetadata": {"trafficType": "ON_DEMAND"},"modelVersion": "gemini-1.5-flash-002","createTime": "2025-05-09T22:52:50.766843Z","responseId": "QoceaPvmLuWcmecPwqig4Ag"}

